pipeline {
    agent any

    environment {
        FAILED_STAGE = "unknown"
        LOG_FILE = "pipeline_error.log"
    }

    stages {

        stage('Cloning the Code') {
            steps {
                script {
                    FAILED_STAGE = env.STAGE_NAME
                }
                git branch: 'main',
                    url: "https://github.com/Pravesh-Sudha/ai-devops-agent.git"
            }
        }

        stage('Building the Docker Image') {
            steps {
                script {
                    FAILED_STAGE = env.STAGE_NAME
                }
                sh '''
                  docker build \
                    -f cicd-copilot/Dockerfile \
                    -t cicd-copilot:v1 \
                    cicd-copilot > ${LOG_FILE} 2>&1
                '''
            }
        }

        stage('Running the Container') {
            steps {
                script {
                    FAILED_STAGE = env.STAGE_NAME
                }
                sh '''
                  docker run --name cicd-copilot \
                    -d -p 3000:3000 cicd-copilot:v2 > ${LOG_FILE} 2>&1
                '''
                echo 'Your application is running on port 3000 🚀'
            }
        }

        stage('Push to Docker Hub') {
            steps {
                script {
                    FAILED_STAGE = env.STAGE_NAME
                }
        
                withCredentials([usernamePassword(
                    credentialsId: 'docker-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
        
                    sh 'echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin >> ${LOG_FILE} 2>&1'
        
                    sh 'docker tag cicd-copilot:v1 $DOCKER_USER/cicd-copilot:v1 >> ${LOG_FILE} 2>&1'
        
                    sh 'docker push $DOCKER_USER/cicd-copilot:v1 >> ${LOG_FILE} 2>&1'
                    
                }
            }
}
    }

    post {
    failure {
        script {
            echo "❌ Pipeline failed at stage: ${FAILED_STAGE}"

            env.AI_STAGE = FAILED_STAGE

            sh """
            echo "📦 Preparing AI failure payload..."

            jq -n \
              --arg stage "$AI_STAGE" \
              --arg job "$JOB_NAME" \
              --arg build_id "$BUILD_ID" \
              --arg logs "\$(tail -n 200 ${LOG_FILE} 2>/dev/null)" \
              '{
                stage: \$stage,
                job: \$job,
                build_id: \$build_id,
                logs: \$logs
              }' > ai_payload.json

            echo "📤 Sending failure context to AI Copilot"

            aws lambda invoke \
              --function-name cicd-ai-copilot \
              --cli-binary-format raw-in-base64-out \
              --payload file://ai_payload.json \
              ai_response.json
            
            
            jq -r '
              .body | fromjson |
              "==============================",
              "🧠 AI Copilot Analysis",
              "==============================",
              "",
              "Stage: \\(.stage)",
              "Category: \\(.analysis.failure_category)",
              "",
              "Root Cause:",
              "\\(.analysis.root_cause)",
              "",
              "Actionable Fixes:",
              (.analysis.actionable_fixes[] | "- " + .),
              "",
              "Suggested Patch:",
              "File: \\(.analysis.suggested_patch.file)",
              "Line: \\(.analysis.suggested_patch.line)",
              "Fix:  \\(.analysis.suggested_patch.fix)",
              "=============================="
            ' ai_response.json
            """
        }
    }
}

}
